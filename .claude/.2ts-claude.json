  "settings": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(node --test:*)",
      "Bash(npx tsc:*)",
      "Bash(tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(eslint:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/*.pem)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)",
      "Read(./**/*.key)",
      "Read(./secrets/**)"
    ],
    "hooks": [
      {
        "event": "PreToolUse",
        "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-tool-use/block-dangerous-commands.cjs\""
      },
      {
        "event": "PreToolUse",
        "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-tool-use/protect-secrets.cjs\""
      }
    ],
    "scalars": {
      "permissions.defaultMode": "plan"
    }
  },
